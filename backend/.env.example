# Copy this file to .env.local for development or .env.production for deployment.
# Keep real secrets in untracked env files or your deployment platform only.

# App runtime
APP_NAME=Clearframe SmartAPI Backend
APP_ENV=development
DEBUG=true

# Security
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Database and cache
# Preferred: provide the full Postgres connection string directly.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres
REDIS_URL=redis://127.0.0.1:6379/0
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CACHE_KEY_PREFIX=clearframe
BROKER_STATUS_CACHE_TTL_SECONDS=30
PORTFOLIO_SNAPSHOT_CACHE_TTL_SECONDS=15

# Optional alternative: if DATABASE_URL is blank, the backend can assemble it from
# the Supabase DB fields below instead.
# SUPABASE_DB_HOST=db.your-project-ref.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# Optional Supabase API config. Only set these if you plan to call Supabase APIs
# directly from the backend in addition to using the Postgres database.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_KEY=your-supabase-api-key

# Broker and market configuration
ANGEL_ONE_TRADING_API_KEY=
ANGEL_ONE_MARKET_API_KEY=
ANGEL_ONE_SOURCE=WEB
ANGEL_ONE_MARKET_FEED_URL=wss://smartapisocket.angelone.in/smart-stream

# App behavior
REQUEST_TIMEOUT_SECONDS=10
RATE_LIMIT_PER_MINUTE=120
SMARTAPI_MOCK_MODE=true
